APP_NAME="Future Shift Advisory"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://futureshiftadvisory.test
# Canonical production origin for the public site (no trailing slash).
PUBLIC_URL=https://futureshiftadvisory.nz

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_NZ

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL via Laravel Herd Pro (see docs/dev-setup.md)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=futureshift_dev
DB_USERNAME=herd
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=secure_local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Future Shift Advisory: Phase 1 platform configuration ---

# AI - if empty, the AiClient resolver binds FakeAiClient (Phase 1 default).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# NZ integration feature flags - all default OFF in Phase 1 (stubs in use).
FEATURE_NZBN_LIVE=false
FEATURE_COMPANIES_OFFICE_LIVE=false
FEATURE_IRD_LIVE=false
FEATURE_FSP_LIVE=false
FSP_API_KEY=
FEATURE_VIRUS_SCAN_LIVE=false

# Calendar sync defaults to fixtures. Enable FEATURE_CALENDAR_LIVE plus a
# provider flag and OAuth credentials before using live Google/Outlook APIs.
FEATURE_CALENDAR_LIVE=false
FEATURE_GOOGLE_CALENDAR_LIVE=false
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
FEATURE_MICROSOFT_GRAPH_LIVE=false
MICROSOFT_GRAPH_CLIENT_ID=
MICROSOFT_GRAPH_CLIENT_SECRET=

# Accounting providers default to fixtures unless their live flag and OAuth
# credentials are provided.
FEATURE_XERO_LIVE=false
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
FEATURE_MYOB_LIVE=false
MYOB_CLIENT_ID=
MYOB_CLIENT_SECRET=
FEATURE_QUICKBOOKS_LIVE=false
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
FEATURE_SAGE_LIVE=false
SAGE_CLIENT_ID=
SAGE_CLIENT_SECRET=
FEATURE_FIGURED_LIVE=false
FIGURED_CLIENT_ID=
FIGURED_CLIENT_SECRET=
FEATURE_WORKFLOWMAX_LIVE=false
WORKFLOWMAX_CLIENT_ID=
WORKFLOWMAX_CLIENT_SECRET=

# Payment gateway feature flags default OFF; fixture clients are used unless live mode is enabled.
FEATURE_STRIPE_LIVE=false
FEATURE_WINDCAVE_LIVE=false
PAYMENT_PRIMARY_GATEWAY=stripe
PAYMENT_MAX_ATTEMPTS=2
PAYMENT_RETRY_DELAY_MINUTES=60
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
WINDCAVE_API_USER=
WINDCAVE_API_KEY=
WINDCAVE_WEBHOOK_SECRET=

# Virus scanning defaults (WO-06). NoopScanner is used unless live mode is true.
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=2
CLAMAV_CHUNK_SIZE=8192
VIRUS_SCAN_NOTICE_TTL_SECONDS=86400

# Integration resilience defaults (WO-05)
INTEGRATION_RETRY_ATTEMPTS=3
INTEGRATION_BREAKER_FAILURE_THRESHOLD=5
INTEGRATION_BREAKER_WINDOW_SECONDS=60
INTEGRATION_BREAKER_OPEN_SECONDS=300
INTEGRATION_CACHE_TTL_SECONDS=900

# Security knobs (see docs/architecture/security-decisions.md).
# MFA is mandatory (spec §4). MFA_REQUIRED may be set false ONLY in local/dev
# while building; it is force-enabled in production regardless (config/security.php).
MFA_REQUIRED=true
SESSION_TIMEOUT_DEFAULT_MINUTES=30
SESSION_TIMEOUT_SUPER_ADMIN_MINUTES=15
SESSION_TIMEOUT_ADVISOR_MINUTES=30
SESSION_TIMEOUT_JUNIOR_ADVISOR_MINUTES=30
SESSION_TIMEOUT_ENTREPRENEUR_MENTOR_MINUTES=30
SESSION_TIMEOUT_CLIENT_MINUTES=60
SESSION_TIMEOUT_ENTREPRENEUR_MINUTES=60
SESSION_TIMEOUT_BROKER_MINUTES=60
SESSION_TIMEOUT_COACH_MINUTES=60
STEP_UP_RISK_THRESHOLD=70
INVITE_TOKEN_TTL_HOURS=168
MFA_FAILED_ATTEMPT_LIMIT=3
MFA_LOCKOUT_MINUTES=15

# Local/dev testing fixture. When true, `php artisan db:seed` also runs the
# comprehensive TestingSeedDataSeeder (seeded clients, advisors, DD, entrepreneur,
# broker/coach workflows; all logins use password "password"). Leave false in
# production. You can also seed it directly without this flag:
#   php artisan db:seed --class=TestingSeedDataSeeder
# See docs/testing-seed-data.md.
SEED_TESTING_DATA=false

# Governed active learning engine. Candidates require approval before any
# implementation path can change runtime behaviour.
FEATURE_ACTIVE_LEARNING=false
LEARNING_REQUIRE_APPROVAL=true
PRIVACY_MIN_COHORT=5

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# Destination for public-site prospect-lead notifications
OWNER_EMAIL=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
