APP_NAME="Future Shift Advisory"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://futureshiftadvisory.test
# DASHBOARD_LAUNCH_TIMING=true
# The tracked VERSION file supplies the standard release number.
# Set only for an exceptional environment-specific release label.
# APP_VERSION_OVERRIDE=1.0.0
# Canonical production origin for the public site (no trailing slash).
PUBLIC_URL=https://futureshiftadvisory.nz

APP_LOCALE=en_NZ
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_NZ

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL via Laravel Herd Pro (see docs/dev-setup.md)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=futureshift_dev
DB_USERNAME=herd
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Use reverb in test/live once the supervised Reverb service is healthy.
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=secure_local
QUEUE_CONNECTION=database

# Self-hosted realtime transport. VITE_* values are compiled into the browser
# build and must point at the public test/live websocket origin.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_SERVER_HOST=127.0.0.1
REVERB_SERVER_PORT=8080
REVERB_HOST=futureshiftadvisory.test
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_ALLOWED_ORIGINS=https://futureshiftadvisory.test
VITE_REVERB_APP_KEY="\${REVERB_APP_KEY}"
VITE_REVERB_HOST="\${REVERB_HOST}"
VITE_REVERB_PORT="\${REVERB_PORT}"
VITE_REVERB_SCHEME="\${REVERB_SCHEME}"

# Client screen support limits, relay discovery, and coturn REST credentials.
# The shared TURN secret stays server-side; never expose it through VITE_*.
SCREEN_SHARE_REQUEST_TIMEOUT_SECONDS=60
SCREEN_SHARE_PICKER_TIMEOUT_SECONDS=90
SCREEN_SHARE_MAX_DURATION_MINUTES=30
SCREEN_SHARE_WARNING_AT_MINUTES=25
SCREEN_SHARE_HEARTBEAT_INTERVAL_SECONDS=10
SCREEN_SHARE_RECONNECT_GRACE_SECONDS=15
SCREEN_SHARE_STUN_URLS=stun:stun.l.google.com:19302
SCREEN_SHARE_TURN_URLS=
SCREEN_SHARE_TURN_SHARED_SECRET=
SCREEN_SHARE_TURN_TTL_SECONDS=600

# Keep guided assistance disabled until explicitly enabled in a test environment.
# It permits only consented in-app pointers and highlights; it never controls input.
CO_BROWSE_ENABLED=false
CO_BROWSE_REQUEST_TIMEOUT_SECONDS=60
CO_BROWSE_MAX_DURATION_MINUTES=20

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Future Shift Advisory: Phase 1 platform configuration ---

# AI - if empty, the AiClient resolver binds FakeAiClient (Phase 1 default).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_OUTPUT_TOKENS=4096

# NZ integration feature flags - all default OFF in Phase 1 (stubs in use).
FEATURE_NZBN_LIVE=false
FEATURE_COMPANIES_OFFICE_LIVE=false
FEATURE_IRD_LIVE=false
FEATURE_FSP_LIVE=false
FSP_API_KEY=
FEATURE_VIRUS_SCAN_LIVE=false

# Stats NZ ADE uses a vault-managed subscription key in-app, with these env
# values available for local fallback/configuring the exact ADE series routes.
FEATURE_STATS_NZ_LIVE=false
STATS_NZ_API_KEY=
STATS_NZ_CPI_RESOURCE_ID=
STATS_NZ_CPI_KEY=all
STATS_NZ_GDP_RESOURCE_ID=
STATS_NZ_GDP_KEY=all
STATS_NZ_UNEMPLOYMENT_RESOURCE_ID=
STATS_NZ_UNEMPLOYMENT_KEY=all

# Calendar sync defaults to fixtures. Enable FEATURE_CALENDAR_LIVE plus a
# provider flag and OAuth credentials before using live Google/Outlook APIs.
FEATURE_CALENDAR_LIVE=false
FEATURE_GOOGLE_CALENDAR_LIVE=false
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
FEATURE_MICROSOFT_GRAPH_LIVE=false
MICROSOFT_GRAPH_TENANT=common
MICROSOFT_GRAPH_AUTHORIZE_URL=https://login.microsoftonline.com/{tenant}/oauth2/v2.0/authorize
MICROSOFT_GRAPH_TOKEN_URL=https://login.microsoftonline.com/{tenant}/oauth2/v2.0/token
MICROSOFT_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0/me
MICROSOFT_GRAPH_SCOPES="Calendars.ReadWrite offline_access"
MICROSOFT_GRAPH_CLIENT_ID=
MICROSOFT_GRAPH_CLIENT_SECRET=

# Accounting providers default to fixtures unless their live flag and OAuth
# credentials are provided.
FEATURE_XERO_LIVE=false
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
FEATURE_MYOB_LIVE=false
MYOB_CLIENT_ID=
MYOB_CLIENT_SECRET=
FEATURE_QUICKBOOKS_LIVE=false
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
FEATURE_SAGE_LIVE=false
SAGE_CLIENT_ID=
SAGE_CLIENT_SECRET=
FEATURE_FIGURED_LIVE=false
FIGURED_CLIENT_ID=
FIGURED_CLIENT_SECRET=
FEATURE_WORKFLOWMAX_LIVE=false
WORKFLOWMAX_CLIENT_ID=
WORKFLOWMAX_CLIENT_SECRET=

# Payment gateway feature flags default OFF; fixture clients are used unless live mode is enabled.
FEATURE_STRIPE_LIVE=false
FEATURE_WINDCAVE_LIVE=false
PAYMENT_PRIMARY_GATEWAY=stripe
PAYMENT_MAX_ATTEMPTS=2
PAYMENT_RETRY_DELAY_MINUTES=60
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
WINDCAVE_API_USER=
WINDCAVE_API_KEY=
WINDCAVE_WEBHOOK_SECRET=

# Virus scanning defaults (WO-06). Local/testing may use the no-op scanner; it
# is ignored in production. Enable FEATURE_VIRUS_SCAN_LIVE in production or
# uploads fail closed to quarantine.
#
# Production:
# FEATURE_VIRUS_SCAN_LIVE=true
# VIRUS_SCAN_ALLOW_NOOP=false
# CLAMAV_HOST=127.0.0.1
# CLAMAV_PORT=3310
VIRUS_SCAN_ALLOW_NOOP=true
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=2
CLAMAV_CHUNK_SIZE=8192
VIRUS_SCAN_NOTICE_TTL_SECONDS=86400

# Integration resilience defaults (WO-05)
INTEGRATION_RETRY_ATTEMPTS=3
INTEGRATION_BREAKER_FAILURE_THRESHOLD=5
INTEGRATION_BREAKER_WINDOW_SECONDS=60
INTEGRATION_BREAKER_OPEN_SECONDS=300
INTEGRATION_CACHE_TTL_SECONDS=900

# Website audit. An advisor must confirm each client URL before it is fetched.
# Leave the PageSpeed key empty to retain the honest "not measured" fallback.
WEBSITE_AUDIT_MAX_PAGES=15
WEBSITE_AUDIT_MAX_TOTAL_BYTES=2000000
WEBSITE_AUDIT_MAX_PAGE_TEXT_BYTES=12000
WEBSITE_AUDIT_TIMEOUT_SECONDS=15
WEBSITE_AUDIT_USER_AGENT="FutureShiftAdvisoryWebsiteAudit/1.0"
PAGESPEED_INSIGHTS_API_KEY=

# Security knobs (see docs/architecture/security-decisions.md).
# MFA is mandatory (spec §4). MFA_REQUIRED may be set false ONLY in local/dev
# while building; it is force-enabled in production regardless (config/security.php).
MFA_REQUIRED=true
SESSION_TIMEOUT_DEFAULT_MINUTES=30
SESSION_TIMEOUT_SUPER_ADMIN_MINUTES=15
SESSION_TIMEOUT_ADVISOR_MINUTES=30
SESSION_TIMEOUT_JUNIOR_ADVISOR_MINUTES=30
SESSION_TIMEOUT_ENTREPRENEUR_MENTOR_MINUTES=30
SESSION_TIMEOUT_CLIENT_MINUTES=60
SESSION_TIMEOUT_ENTREPRENEUR_MINUTES=60
SESSION_TIMEOUT_BROKER_MINUTES=60
SESSION_TIMEOUT_COACH_MINUTES=60
STEP_UP_RISK_THRESHOLD=70
INVITE_TOKEN_TTL_HOURS=168
MFA_FAILED_ATTEMPT_LIMIT=3
MFA_LOCKOUT_MINUTES=15

# Local/dev testing fixture. When true, `php artisan db:seed` also runs the
# comprehensive TestingSeedDataSeeder (seeded clients, advisors, DD, entrepreneur,
# broker/coach workflows; all logins use password "password"). Leave false in
# production. You can also seed it directly without this flag:
#   php artisan db:seed --class=TestingSeedDataSeeder
# See docs/testing-seed-data.md.
SEED_TESTING_DATA=false

# Governed active learning engine. Candidates require approval before any
# implementation path can change runtime behaviour.
FEATURE_ACTIVE_LEARNING=false
LEARNING_REQUIRE_APPROVAL=true
PRIVACY_MIN_COHORT=5

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# Destination for public-site prospect-lead notifications
OWNER_EMAIL=
GOOGLE_ANALYTICS_MEASUREMENT_ID=
POSTMARK_API_KEY=
RESEND_API_KEY=
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=
LOG_SLACK_WEBHOOK_URL=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
