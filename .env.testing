APP_ENV=testing
APP_KEY=base64:0000000000000000000000000000000000000000000=
APP_DEBUG=true

# PostgreSQL test database (see docs/dev-setup.md)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=futureshift_test
DB_USERNAME=herd
DB_PASSWORD=

# Tests run synchronously; no queue worker required.
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
CACHE_STORE=array
MAIL_MAILER=array
BROADCAST_CONNECTION=null

# AI is always faked in tests. Never bind the live client here.
ANTHROPIC_API_KEY=
FEATURE_NZBN_LIVE=false
FEATURE_COMPANIES_OFFICE_LIVE=false
FEATURE_IRD_LIVE=false
FEATURE_VIRUS_SCAN_LIVE=false

MFA_REQUIRED=true

BCRYPT_ROUNDS=4
PULSE_ENABLED=false
TELESCOPE_ENABLED=false
NIGHTWATCH_ENABLED=false
